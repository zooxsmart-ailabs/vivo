{
  "name": "@vivo/data-vis",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @vivo/zoox-map-api dev",
    "dev:web": "pnpm --filter @vivo/zoox-map-web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "check": "pnpm -r check",
    "format": "prettier --write \"**/*.{ts,vue,json,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "esbuild",
      "protobufjs"
    ]
  }
}
