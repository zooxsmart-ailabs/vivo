{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@vivo/shared": ["../../packages/shared/src"],
      "@vivo/shared/*": ["../../packages/shared/src/*"],
      "@vivo/zoox-map-api/*": ["../api/*"]
    }
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "app/__tests__/**",
    "cypress/**"
  ]
}
