# ===========================================================================
# data-core/.env.example — Zoox x Vivo GeoIntelligence Infrastructure
# ===========================================================================
# Copy to .env and fill in production values.

# ---------------------------------------------------------------------------
# Main Database (default — always starts)
# PostgreSQL 18 + TimescaleDB + PostGIS
# ---------------------------------------------------------------------------
PG_PORT=5437
POSTGRES_DB=vivo_geointel
POSTGRES_USER=vivo
POSTGRES_PASSWORD=changeme-in-production

# ---------------------------------------------------------------------------
# OpenMetadata Catalog (docker compose --profile catalog up)
# ---------------------------------------------------------------------------
OM_VERSION=1.12.3
OM_PORT=8585
OM_PG_PASSWORD=openmetadata
OM_ADMIN_PASSWORD=admin

# GeoIntelligence DB connection (for OM to discover schemas)
# Uses Docker DNS — "postgres" is the main DB service above.
GEOINTEL_PG_HOST=postgres
GEOINTEL_PG_PORT=5437
GEOINTEL_PG_USER=vivo
GEOINTEL_PG_PASSWORD=changeme-in-production
GEOINTEL_PG_DATABASE=vivo_geointel

# ---------------------------------------------------------------------------
# SigNoz Observability (docker compose --profile observability up)
# Traces, Metrics, Logs via OpenTelemetry
# ---------------------------------------------------------------------------
SIGNOZ_FRONTEND_PORT=3301
SIGNOZ_OTEL_GRPC_PORT=4317
SIGNOZ_OTEL_HTTP_PORT=4318

# NestJS app (data-viz) should set these env vars to send traces:
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
